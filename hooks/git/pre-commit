#!/usr/bin/env sh
# web-god pre-commit hook
# Runs lint-staged on staged files (lint + format)
# Install: cp hooks/git/pre-commit .husky/pre-commit && chmod +x .husky/pre-commit

# Run lint-staged (configured in package.json)
npx lint-staged

# Check for debug artifacts
DEBUGGERS=$(git diff --cached --name-only -z | xargs -0 grep -l 'debugger\|console\.log' 2>/dev/null | grep -E '\.(ts|tsx|js|jsx)$' | grep -v '\.test\.' || true)
if [ -n "$DEBUGGERS" ]; then
  echo ""
  echo "⚠️  WARNING: Debug statements found in staged files:"
  echo "$DEBUGGERS"
  echo ""
  echo "Remove console.log/debugger before committing."
  echo "Use 'git commit --no-verify' to bypass (not recommended)."
  exit 1
fi

# Check for .env files being committed
ENV_FILES=$(git diff --cached --name-only | grep -E '^\.env(\.local|\.production|\.staging)?$' || true)
if [ -n "$ENV_FILES" ]; then
  echo ""
  echo "🚨 BLOCKED: Attempting to commit environment files:"
  echo "$ENV_FILES"
  echo ""
  echo "Add these to .gitignore. Only .env.example should be committed."
  exit 1
fi
