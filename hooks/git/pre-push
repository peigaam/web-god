#!/usr/bin/env sh
# web-god pre-push hook
# Runs type check and tests before pushing
# Install: cp hooks/git/pre-push .husky/pre-push && chmod +x .husky/pre-push

echo ">> Pre-push: Type checking..."
if ! npx tsc --noEmit; then
  echo "❌ TypeScript errors found. Fix before pushing."
  exit 1
fi
echo "  ✅ Types clean"

echo ">> Pre-push: Running tests..."
if ! (npm test -- --run 2>/dev/null || npm test 2>/dev/null); then
  echo "❌ Tests failed. Fix before pushing."
  exit 1
fi
echo "  ✅ Tests passed"

echo ">> Pre-push: Building..."
if ! npm run build 2>/dev/null; then
  echo "❌ Build failed. Fix before pushing."
  exit 1
fi
echo "  ✅ Build passed"

echo ""
echo "✅ All pre-push checks passed. Pushing..."
